# ------------------------------------------------------
# Centralized variables for the dotfiles architecture.
# All scripts and configs source this file.

# ── User ──────────────────────────────────────────────
USERNAME="kamal"
TERMINAL="kitty"
BROWSER="firefox"
EDITOR="code"
FILEMANAGER="dolphin"

# ── Monitor ───────────────────────────────────────────
# Use 'hyprctl monitors' to find your monitor names
MONITOR_NAME="eDP-1"
MONITOR_RES="preferred"
MONITOR_POS="auto"
MONITOR_SCALE="1"

# ── Appearance ────────────────────────────────────────
THEME="Catppuccin-Mocha"
GTK_THEME="Catppuccin-Mocha"
ICON_THEME="Tela-circle-dracula"
CURSOR_THEME="Bibata-Modern-Ice"
CURSOR_SIZE=24

# ── Fonts ─────────────────────────────────────────────
FONT_MAIN="Cantarell"
FONT_MONO="CaskaydiaCove Nerd Font Mono"
FONT_SIZE=10

# ── Hyprland Specifics ────────────────────────────────
GAPS_IN=5
GAPS_OUT=10
BORDER_SIZE=2
ROUNDING=10
ANIMATION_SPEED=5
